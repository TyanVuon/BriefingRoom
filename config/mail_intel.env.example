# Copy to config/mail_intel.env (gitignored). Stack config only — no passwords or API keys on disk.
# For deploy login and third-party keys, export at runtime (see docker/README-mail-intel.md).

# --- Obsidian (Docker: host path in .env.mail-intel; container uses /vault) ---
OBSIDIAN_VAULT_PATH=
OBSIDIAN_MAIL_INTEL_FOLDER=Mail Intel

# --- Agent ---
MAIL_INTEL_AGENT_ID=
MAIL_INTEL_LLM_ID=openai/gpt-oss-120b@openai/gpt-oss-120b@OpenAI-API-Compatible
RAGFLOW_IMAP_CONNECTOR_ID=

# Bare-metal dev: http://localhost:9380
# Docker init job: http://ragflow-mail-intel:9380 (set automatically in compose)
RAGFLOW_API_BASE=http://localhost:9380
RAGFLOW_TENANT_ID=
RAGFLOW_USER_ID=

# --- HSM (hardware security module — zero-trust gate, required after every refresh) ---
MAIL_INTEL_RP_ID=localhost
MAIL_INTEL_RP_NAME=RAGFlow Mail Intel
# Full Docker (nginx :80): http://localhost
# Vite dev only: http://localhost:9222
MAIL_INTEL_RP_ORIGIN=http://localhost

# Server JWT backstop (default 24h); browser session ends on F5 refresh only
MAIL_INTEL_HARDWARE_TOKEN_TTL_SEC=86400
# MAIL_INTEL_HARDWARE_STORE_KEY=   # set in shell or gitignored env — encrypts credential files

# Local secrets vault (TOTP + AES-256-GCM) — master key never in files
# MAIL_INTEL_VAULT_MASTER=
# MAIL_INTEL_VAULT_SESSION_TTL_SEC=3600
# MAIL_INTEL_OBSIDIAN_2FA=true

# Short-lived token from HSM unlock in explore UI (deploy only)
HARDWARE_AUTH_TOKEN=
