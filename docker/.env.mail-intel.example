# Mail Intelligence Docker stack — merge into docker/.env or use:
#   docker compose --env-file .env --env-file .env.mail-intel ...

# Doc engine: Infinity (lighter than Elasticsearch)
DOC_ENGINE=infinity
COMPOSE_PROFILES=infinity
DEVICE=cpu

# Apple Silicon: do NOT set platform linux/amd64 — native arm64 uses CPU-only deps (no onnxruntime-gpu)

# Host entry (only nginx published)
SVR_WEB_HTTP_PORT=80
SVR_WEB_HTTPS_PORT=443
# Do not publish API to host in production (ragflow-mail-intel service omits 9380:9380)
SVR_HTTP_PORT=9380

# Obsidian vault on host — bind-mounted into ragflow container at /vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
OBSIDIAN_MAIL_INTEL_FOLDER="Mail Intel"

# HSM (hardware security module) — relying party must match browser URL (full Docker uses port 80)
MAIL_INTEL_RP_ID=localhost
MAIL_INTEL_RP_ORIGIN=http://localhost
MAIL_INTEL_RP_NAME=RAGFlow Mail Intel

# Server JWT backstop for hardware session (default 24h); client session ends on F5 only
MAIL_INTEL_HARDWARE_TOKEN_TTL_SEC=86400
# Encrypt enrolled credential blobs at rest (generate locally — never commit)
# MAIL_INTEL_HARDWARE_STORE_KEY=
# Local secrets vault — master key in host shell only (never in compose files)
# MAIL_INTEL_VAULT_MASTER=
# MAIL_INTEL_VAULT_SESSION_TTL_SEC=3600
# MAIL_INTEL_OBSIDIAN_2FA=true

# Agent id for one-shot deploy (non-secret)
MAIL_INTEL_AGENT_ID=

# Deploy login: export in your shell before `mail-intel-deploy` — never store passwords here.
#   export RAGFLOW_API_EMAIL='you@example.com'
#   export RAGFLOW_API_PASSWORD='...'
# See docker/README-mail-intel.md

# Optional: reduce memory if host is tight (Infinity uses less than ES)
# MEM_LIMIT=4294967296
